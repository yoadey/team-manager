# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Postgres credentials (used by docker-compose)
POSTGRES_USER=teammanager
POSTGRES_PASSWORD=teammanager
POSTGRES_DB=teammanager

# Backend secrets — generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# JWT keys — leave empty to auto-generate ephemeral keys in dev (COOKIE_SECURE=false)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=
