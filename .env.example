# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Postgres credentials (used by docker-compose)
POSTGRES_USER=teammanager
POSTGRES_PASSWORD=teammanager
POSTGRES_DB=teammanager

# Backend connection string (needed when running backend outside docker-compose)
# DATABASE_URL=postgres://teammanager:teammanager@localhost:5432/teammanager?sslmode=disable

# Backend secrets — generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# JWT keys — leave empty to auto-generate ephemeral keys in dev (requires COOKIE_SECURE=false)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Optional backend settings (defaults shown)
# PORT=8080
# ALLOWED_ORIGINS=http://localhost:5173
# PUBLIC_BASE_URL=http://localhost:5173
# SESSION_TTL_HOURS=720
# COOKIE_SECURE=false
# ERROR_TYPE_BASE_URI=https://your-domain.com/errors/
# Protect the Prometheus /metrics endpoint with a bearer token. When unset,
# /metrics is open (intended for local dev or a trusted private network).
# METRICS_TOKEN=

# Rate limiting (defaults shown)
# Global per-IP request rate limit, in requests per second.
# RATE_LIMIT_RPS=100
# Per-IP login attempt limit per minute (brute-force protection).
# LOGIN_RATE_LIMIT_PER_MIN=5
# CIDRs of reverse proxies/load balancers trusted to set X-Forwarded-For /
# X-Real-IP for rate limiting. Empty (default) trusts nothing — required if
# deploying behind a proxy, see docs/operations.md#rate-limiting.
# TRUSTED_PROXY_CIDRS=

# Observability (all optional; features disabled when unset)
# OpenTelemetry tracing: set the OTLP/HTTP collector endpoint to enable. The
# OTel SDK reads the standard OTEL_* variables.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=team-manager-backend
# Backend error tracking via Sentry (mirrors the frontend; disabled when empty).
# SENTRY_DSN=
# ENVIRONMENT=development

# Cookie key rotation (preferred over COOKIE_ENCRYPTION_KEY): comma-separated
# AES-256 keys, newest first. Encryption uses the first, decryption tries all.
# See CLAUDE.md's key-rotation runbook for the zero-downtime two-restart flow.
# COOKIE_ENCRYPTION_KEYS=
# HMAC key (32 bytes, hex or base64) signing keyset pagination cursors so
# clients can't forge them. Unsigned base64 cursors are used when unset.
# PAGINATION_HMAC_KEY=
# Minimum log level: debug | info | warn | error (default info).
# LOG_LEVEL=info
# Allow an open, unauthenticated /metrics when COOKIE_SECURE=true and no
# METRICS_TOKEN is set (otherwise startup fails). Use only when /metrics is
# restricted at the network layer.
# METRICS_ALLOW_OPEN=false
# Data retention (days) before the daily retention job deletes rows.
# RETENTION_NOTIFICATIONS_DAYS=90
# RETENTION_SESSIONS_DAYS=30
# RETENTION_AUDIT_LOG_DAYS=365
# Emitted verbatim as the RFC 8594 Deprecation + Sunset response headers.
# API_DEPRECATION_DATE=

# Object storage for images (S3-compatible / MinIO). Required in production
# (COOKIE_SECURE=true). docker-compose provides a local MinIO with these values.
# S3_ENDPOINT=http://localhost:9000
# S3_REGION=us-east-1
# S3_BUCKET=team-manager
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_USE_PATH_STYLE=true
# S3_PUBLIC_BASE_URL=http://localhost:9000
