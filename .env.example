# Copy to .env and fill in values for local development.
# Never commit .env to version control.

# Postgres credentials (used by docker-compose)
POSTGRES_USER=teammanager
POSTGRES_PASSWORD=teammanager
POSTGRES_DB=teammanager

# Backend connection string (needed when running backend outside docker-compose)
# DATABASE_URL=postgres://teammanager:teammanager@localhost:5432/teammanager?sslmode=disable

# Backend secrets — generate with: openssl rand -base64 32
COOKIE_ENCRYPTION_KEY=

# JWT keys — leave empty to auto-generate ephemeral keys in dev (requires COOKIE_SECURE=false)
JWT_PRIVATE_KEY=
JWT_PUBLIC_KEY=

# Optional backend settings (defaults shown)
# PORT=8080
# ALLOWED_ORIGINS=http://localhost:5173
# PUBLIC_BASE_URL=http://localhost:5173
# SESSION_TTL_HOURS=720
# COOKIE_SECURE=false
# ERROR_TYPE_BASE_URI=https://your-domain.com/errors/
# Protect the Prometheus /metrics endpoint with a bearer token. When unset,
# /metrics is open (intended for local dev or a trusted private network).
# METRICS_TOKEN=

# Rate limiting (defaults shown)
# Global per-IP request rate limit, in requests per second.
# RATE_LIMIT_RPS=100
# Per-IP login attempt limit per minute (brute-force protection).
# LOGIN_RATE_LIMIT_PER_MIN=5
# CIDRs of reverse proxies/load balancers trusted to set X-Forwarded-For /
# X-Real-IP for rate limiting. Empty (default) trusts nothing — required if
# deploying behind a proxy, see docs/operations.md#rate-limiting.
# TRUSTED_PROXY_CIDRS=

# Observability (all optional; features disabled when unset)
# OpenTelemetry tracing: set the OTLP/HTTP collector endpoint to enable. The
# OTel SDK reads the standard OTEL_* variables.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
# OTEL_SERVICE_NAME=team-manager-backend
# Backend error tracking via Sentry (mirrors the frontend; disabled when empty).
# SENTRY_DSN=
# ENVIRONMENT=development
