# App configuration
VITE_APP_NAME=Teamverwaltung

# Storage key prefix for localStorage (mock backend)
VITE_STORAGE_KEY_PREFIX=tv_db_

# Mock API delay range in milliseconds
VITE_MOCK_DELAY_MIN=120
VITE_MOCK_DELAY_MAX=320

# Error tracking (leave empty to disable)
VITE_SENTRY_DSN=

# API base URL (for real backend; leave empty to use mock)
VITE_API_BASE_URL=

# VAPID public key for Web Push (must match the backend's VAPID_PUBLIC_KEY;
# leave empty to disable the push-notification opt-in toggle)
VITE_VAPID_PUBLIC_KEY=
